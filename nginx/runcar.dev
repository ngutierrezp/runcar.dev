# DEPLOY_MARKER: runcar-nginx-v3-apex-only
server {
    listen 80;
    server_name www.runcar.dev;
    return 301 https://runcar.dev$request_uri;
}

# HTTP: apex → animación por curl
server {
    listen 80;
    server_name runcar.dev;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# HTTPS: www → apex
server {
    listen 443 ssl;
    http2 on;
    server_name www.runcar.dev;

    ssl_certificate /etc/letsencrypt/live/runcar.dev/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/runcar.dev/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    return 301 https://runcar.dev$request_uri;
}

# HTTPS: apex — HTML, CSS, favicon desde disco (un solo root, sin location regex)
server {
    listen 443 ssl;
    http2 on;
    server_name runcar.dev;

    ssl_certificate /etc/letsencrypt/live/runcar.dev/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/runcar.dev/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    include /etc/nginx/mime.types;
    default_type application/octet-stream;
    charset utf-8;

    root /home/ngutierrezp/runcar.dev/html;
    index index.html;

    # Explicit TTL on static assets so edge caches (e.g. Cloudflare) revalidate after
    # deploys. Without this, CSS/JS can stay pinned for days while HTML updates.
    location ~* \.(?:css|js|ico|svg|png|jpg|jpeg|gif|webp|woff2?)$ {
        add_header Cache-Control "public, max-age=300, must-revalidate" always;
        try_files $uri =404;
    }

    location / {
        add_header Cache-Control "public, max-age=300, must-revalidate" always;
    }
}
